{
  "projects": {
    "/path/to/QuantEvoLens": {
      "mcpServers": {
        "quantevolens": {
          "type": "stdio",
          "command": "/path/to/QuantEvoLens/.venv/bin/python",
          "args": ["mcp_server.py"],
          "env": {
            "SUPABASE_USER_ID": "your-supabase-user-id",
            "TICKFLOW_API_KEY": "your-tickflow-api-key"
          }
        }
      }
    }
  }
}
